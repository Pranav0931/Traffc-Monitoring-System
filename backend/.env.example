# Environment Configuration
# Copy this file to .env and customize as needed

# Application Settings
APP_NAME=AI Traffic Monitoring System
APP_VERSION=1.0.0
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Video Source
# Options: "demo", "0" (webcam), RTSP URL, or file path
VIDEO_SOURCE=demo
VIDEO_FPS=30
FRAME_WIDTH=1280
FRAME_HEIGHT=720

# YOLO Model
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
DEVICE=auto

# Location Settings
LOCATION_NAME=Main Road Signal, Agur
LOCATION_LAT=12.7805
LOCATION_LNG=77.6051

# Congestion Thresholds
CONGESTION_LOW_THRESHOLD=10
CONGESTION_MEDIUM_THRESHOLD=20

# Update Intervals (seconds)
WEBSOCKET_UPDATE_INTERVAL=2.0
CONGESTION_UPDATE_INTERVAL=3.0
